{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.z4yt0n.dev-server-manager",
  "version": "0.1.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/index.html",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  },
  "nativeAllowList": [
    "app.*",
    "window.*",
    "filesystem.*",
    "os.*",
    "events.*",
    "computer.*",
    "storage.*",
    "debug.*",
    "extensions.*"
  ],
  "modes": {
    "window": {
      "title": "Dev Server Manager",
      "width": 1100,
      "height": 740,
      "minWidth": 800,
      "minHeight": 540,
      "fullScreen": false,
      "alwaysOnTop": false,
      "icon": "/resources/icon.png",
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "DevServerManager",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}
